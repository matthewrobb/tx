{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/cli/**/*.ts",
    "src/config/**/*.ts",
    "src/engine/**/*.ts",
    "src/daemon/**/*.ts",
    "src/stories/**/*.ts",
    "src/agents/**/*.ts",
    "src/types/**/*.ts"
  ],
  "exclude": ["build/**", "**/*.test.ts"]
}
