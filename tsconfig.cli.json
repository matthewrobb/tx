{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/cli/**/*.ts",
    "src/config/**/*.ts",
    "src/state/**/*.ts",
    "src/notes/**/*.ts",
    "src/tasks/**/*.ts",
    "src/session/**/*.ts",
    "src/artifacts/**/*.ts",
    "src/presets/**/*.ts"
  ],
  "exclude": ["build/**", "**/*.test.ts"]
}
