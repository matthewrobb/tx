{
  "name": "@twisted.works/tx",
  "version": "4.2.0",
  "description": "Data-driven DAG workflow engine for agentic development — issues, cycles, sessions, and expression-based step automation",
  "type": "module",
  "license": "GPL-3.0-only",
  "author": "Matt Robb",
  "repository": {
    "type": "git",
    "url": "https://github.com/matthewrobb/tx.git"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "tx": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "schemas/",
    "skills/"
  ],
  "scripts": {
    "build": "tsx build/build.ts",
    "build:cli": "tsc -p tsconfig.cli.json",
    "prepublishOnly": "npm run build:cli && npm run build",
    "dev": "node ./dist/cli/index.js",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22",
    "build-md": "^0.4.5",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^2"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.3",
    "commander": "^14.0.3",
    "sock-daemon": "^1.4.2",
    "symlink-dir": "^10.0.1",
    "xstate": "^5.30.0"
  }
}
